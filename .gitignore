# =========================================================================
#  Build output — regenerated by Vercel on every deploy (node tools/build-pages.mjs).
#  Not committed, so adding a language no longer rewrites every page (no churn / conflicts).
#  Live output is identical: Vercel runs build-pages.mjs and serves the freshly built files.
# =========================================================================

# Per-language static pages live in /<code>/ directories at the repo root.
# Ignore every root-level directory, then un-ignore the real source directories.
# (When you add a new top-level SOURCE dir, whitelist it here too.)
/*/
!/i18n/
!/tools/
!/.github/
!/.claude/

# Generated site files (root-level)
/sitemap.xml
/llms.txt

# Per-language OG images are no longer used — a single shared /og.png serves all languages.
/og-*.png

# Local cruft
.DS_Store
Thumbs.db
node_modules/
/tmp/
